# Server Configuration
PORT=10000
NODE_ENV=production

# Database Connection
# Replace with your MongoDB Atlas Connection String for production
MONGO_URI=mongodb+srv://<username>:<password>@cluster0.mongodb.net/mytaxi?retryWrites=true&w=majority

# Security
JWT_SECRET=mytaxi_production_super_secret_key_2024
JWT_EXPIRE=30d

# Frontend & CORS
# Replace with your deployed frontend URL (e.g., Vercel or Netlify)
FRONTEND_URL=https://mytaxi-admin.vercel.app

# Cloudinary (Optional, highly recommended for production file uploads on Render)
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=
